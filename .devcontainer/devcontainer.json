{
  "name": "ASL Sign Language Translator",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "bash setup.sh",
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.vscode-pylance"]
    }
  }
}